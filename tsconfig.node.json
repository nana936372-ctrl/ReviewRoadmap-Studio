{
  "compilerOptions": {
    "composite": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "outDir": "./node_modules/.tmp/tsconfig-node",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo"
  },
  "include": [
    "vite.config.ts",
    "src/domain/types.ts",
    "src/lib/appStorePageReviews.ts",
    "src/lib/analysis/classify.ts",
    "src/lib/analysis/normalize.ts",
    "src/lib/analysis/roadmap.ts",
    "src/lib/analysis/scoring.ts",
    "src/lib/analysis/semantic.ts"
  ]
}
