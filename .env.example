# Copy this file to .env.local and fill in your local values.
# Never commit .env.local or any real API key.

# Option A: OpenAI Responses API.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=https://api.openai.com/v1

# Option B: DeepSeek / OpenAI-compatible Chat Completions.
# Fill this section instead of the OpenAI section if you use DeepSeek.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
